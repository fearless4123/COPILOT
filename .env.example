# Copy this file to .env and fill in your values
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# NEVER commit your real .env file / Gerçek .env dosyanızı asla commit etmeyin

# Target / Hedef
TARGET_HOST=example.com
TARGET_PORT=80

# Output / Çıktı
OUTPUT_DIR=./reports
LOG_LEVEL=info

# Application Settings / Uygulama Ayarları
APP_PORT=8080
APP_NAME=CopilotRCESimulator
